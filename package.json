{
  "name": "neolithic-app",
  "version": "1.0.0",
  "description": "Task manager, browser tab organizer, and window manager",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "prisma generate && electron-vite dev",
    "build": "electron-vite build",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "postinstall": "prisma generate && electron-builder install-app-deps",
    "release:win": "prisma generate && electron-vite build && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --win --publish never",
    "dist:win": "npm run release:win"
  },
  "dependencies": {
    "@electron-toolkit/utils": "^3.0.0",
    "@opentelemetry/api": "^1.9.1",
    "@prisma/client": "^5.22.0",
    "@radix-ui/react-checkbox": "^1.1.2",
    "@radix-ui/react-dialog": "^1.1.2",
    "@radix-ui/react-dropdown-menu": "^2.1.2",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-select": "^2.1.2",
    "@radix-ui/react-separator": "^1.1.0",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-tabs": "^1.1.1",
    "@radix-ui/react-toast": "^1.2.2",
    "better-auth": "^1.2.7",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "^16.4.5",
    "electron-store": "^8.2.0",
    "lucide-react": "^0.454.0",
    "prisma": "^5.22.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.27.0",
    "sonner": "^1.7.0",
    "tailwind-merge": "^2.5.4",
    "zod": "^3.23.8",
    "zustand": "^4.5.5"
  },
  "build": {
    "appId": "com.neolithic.app",
    "productName": "Neolithic",
    "asar": true,
    "asarUnpack": [
      "**/prisma/**",
      "**/.prisma/**",
      "**/@prisma/**",
      "**/query_engine*",
      "**/libquery_engine*"
    ],
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "package.json",
      "node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "prisma",
        "to": "prisma",
        "filter": [
          "**/*",
          "!dev.db",
          "!dev.db-journal"
        ]
      },
      {
        "from": "node_modules/.prisma",
        "to": "node_modules/.prisma"
      },
      {
        "from": "node_modules/@prisma/client",
        "to": "node_modules/@prisma/client"
      }
    ],
    "win": {
      "sign": null,
      "signAndEditExecutable": false,
      "target": [
        "nsis"
      ],
      "artifactName": "${productName}-Setup.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false
    }
  },
  "optionalDependencies": {
    "windows-window-manager": "^1.0.0"
  },
  "devDependencies": {
    "@electron-toolkit/tsconfig": "^1.0.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "electron": "^33.2.1",
    "cross-env": "^7.0.3",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.6.3",
    "vite": "^5.4.21"
  }
}
