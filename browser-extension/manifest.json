{
  "manifest_version": 3,
  "name": "Neolithic Tab Monitor",
  "version": "1.0.0",
  "description": "Tracks browser tab usage and syncs with the Neolithic desktop app.",
  "permissions": ["tabs", "storage"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Neolithic Tab Monitor"
  }
}
